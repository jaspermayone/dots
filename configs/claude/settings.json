{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "teammateMode": "tmux",
  "bypassPermissions": true,
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      "vendor/bundle",
      "vendor/cache",
      "vendor/gems",
      "vendor/ruby",
      "target",
      ".cache"
    ]
  },
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": [
        "mcp"
      ]
    }
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(gh *)",
      "Bash(wut *)",
      "Bash(try *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git worktree *)",
      "Bash(nix *)",
      "Bash(darwin-rebuild *)",
      "Bash(nixos-rebuild *)",
      "Bash(brew *)",
      "Bash(boxcar *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bundle *)",
      "Bash(rails *)",
      "Bash(rake *)",
      "Bash(cargo *)",
      "Bash(make *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(* --help *)",
      "Read",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(git push *)",
      "Bash(git push)"
    ],
    "deny": [
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets.*)",
      "Read(*.age)"
    ]
  }
}